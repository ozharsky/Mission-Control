{
  "version": 2,
  "routes": [
    {
      "src": "/js/api/printers",
      "dest": "/api/printers.js",
      "headers": {
        "Access-Control-Allow-Origin": "https://ozharsky.github.io",
        "Access-Control-Allow-Methods": "GET, POST, OPTIONS",
        "Access-Control-Allow-Headers": "Content-Type, Authorization"
      }
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
